# Optional pricing config override JSON
# PRICING_CONFIG_JSON='{"starter":{"limits":{"maxActiveInvites":1}},"creator":{"priceLabel":"$12/mo"},"studio":{"priceLabel":"$29/mo"}}'
CORE_TEMPLATE_IDS="valentine,birthday"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
