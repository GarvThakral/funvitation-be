PORT=3000
# Use exact frontend URL in production, e.g. https://funvitation-fe.vercel.app
CORS_ORIGIN=*
APP_BASE_URL="http://localhost:5173"

# Firebase Admin
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY=""
